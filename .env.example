# Silas environment variables
# Copy this file to .env.local and fill in real values.
# Never commit .env.local to git.

# === Supabase (free tier) ===
# Create a project at supabase.com, then:
# Project Settings -> API -> URL
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# Project Settings -> API -> Project API keys -> anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxx...
# Project Settings -> API -> Project API keys -> service_role (SECRET, server only)
SUPABASE_SERVICE_ROLE_KEY=eyJxxx...

# === Anthropic (the actual brain) ===
# console.anthropic.com -> Settings -> API Keys -> Create Key
ANTHROPIC_API_KEY=sk-ant-xxx

# === OpenAI (for embeddings - cheaper than Anthropic for this) ===
# platform.openai.com -> API Keys -> Create new
OPENAI_API_KEY=sk-xxx

# === ElevenLabs (voice output — Silas speaks his replies) ===
# elevenlabs.io -> Profile -> API Key. Server-only; NEVER expose to the client.
ELEVENLABS_API_KEY=sk_xxx
# elevenlabs.io -> Voices -> (your voice) -> ID. The same voice you use elsewhere.
ELEVENLABS_VOICE_ID=xxxxxxxxxxxxxxxxxxxx

# === App config ===
# Your local Brain vault path - the migration script reads from here ONCE
BRAIN_VAULT_PATH=C:\Users\hudso\OneDrive\Documents\Claude\Projects\Claude Projects\Brain
# The URL for magic-link callbacks. localhost in dev, your vercel URL in prod.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# === Model choices (defaults are good, change only if you want) ===
ANTHROPIC_CHAT_MODEL=claude-sonnet-4-6
ANTHROPIC_CHEAP_MODEL=claude-haiku-4-5-20251001
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
